# Backend service env (consumed by the api container). Mirrors api/.env.example.

DATABASE_URL=postgresql+psycopg://firststepai:firststepai@postgres:5432/firststepai
ASYNC_DATABASE_URL=postgresql+asyncpg://firststepai:firststepai@postgres:5432/firststepai
REDIS_URL=redis://redis:6379/0

HF_TOKEN=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
LLM_PROVIDER=groq

AUTH_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
REMEMBER_ME_MAX_AGE=2592000
RESET_TOKEN_MAX_AGE=900
BCRYPT_ROUNDS=12

CORS_ORIGINS=http://localhost:8080,http://localhost:5173
COOKIE_SECURE=false
COOKIE_DOMAIN=

COMPANY_NAME=Umbrella Corporation
COMPANY_LOGO_URL=https://upload.wikimedia.org/wikipedia/commons/0/0e/Umbrella_Corporation_logo.svg
COMPANY_FAVICON=⛛
THEME=dark

DATA_DIR=/data
VECTORSTORE_PATH=/data/vectorstore
UPLOADS_PATH=/data/uploads
# Seed PDF + Chroma index are mounted read-only at /seed (see docker-compose).
POLICIES_PDF=/seed/umbrella_corp_policies.pdf
ANONYMIZED_TELEMETRY=false
LOG_LEVEL=INFO
