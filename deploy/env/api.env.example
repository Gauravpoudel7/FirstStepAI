# FirstStep AI — API runtime config (read by uvicorn container).
# Copy to deploy/env/api.env and override AUTH_SECRET / GROQ_API_KEY before going live.

DATABASE_URL=postgresql+psycopg://firststepai:firststepai@postgres:5432/firststepai
REDIS_URL=redis://redis:6379/0

# LLM provider. Set LLM_PROVIDER=groq and GROQ_API_KEY=... in production.
LLM_PROVIDER=groq
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=

# Auth — change AUTH_SECRET in prod.
AUTH_SECRET=change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
REMEMBER_ME_MAX_AGE=2592000
RESET_TOKEN_MAX_AGE=900
BCRYPT_ROUNDS=12

# CORS / cookies.
CORS_ORIGINS=http://localhost:8080,http://localhost
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Branding.
COMPANY_NAME=Umbrella Corporation
THEME=dark

# Storage paths inside the container.
DATA_DIR=/data
VECTORSTORE_PATH=/data/vectorstore
UPLOADS_PATH=/data/uploads
POLICIES_PDF=/seed/umbrella_corp_policies.pdf

# Misc.
ANONYMIZED_TELEMETRY=false
LOG_LEVEL=INFO