opics."}, {"id": "data_umbrella_corp_policies_source_citation", "label": "Mandatory Source Citation", "file_type": "rationale", "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 4.7.1", "source_url": null, "captured_at": null, "author": "Umbrella Corporation Human Resources Department", "contributor": null, "rationale": "Every answer must cite its policy section so employees and auditors can verify the source, making the system auditable."}, {"id": "data_umbrella_corp_policies_scope_confinement", "label": "Scope Confinement to Policy Corpus", "file_type": "rationale", "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 4.7.1", "source_url": null, "captured_at": null, "author": "Umbrella Corporation Human Resources Department", "contributor": null, "rationale": "Jailbreak-resistant system prompt confines the agent to Umbrella Corp policy content, preventing off-topic or unsafe responses in an HR context."}], "edges": [{"source": "data_umbrella_corp_policies_firststepai", "target": "data_umbrella_corp_policies_assignment_rules", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 1", "weight": 1.0}, {"source": "data_umbrella_corp_policies_assignment_rules", "target": "data_umbrella_corp_policies_quiz_format", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 4.7.1", "weight": 1.0}, {"source": "data_umbrella_corp_policies_assignment_rules", "target": "data_umbrella_corp_policies_mixed_question_types", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 4.7.1", "weight": 1.0}, {"source": "data_umbrella_corp_policies_assignment_rules", "target": "data_umbrella_corp_policies_llm_quiz_generation", "relation": "r