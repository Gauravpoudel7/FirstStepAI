{"nodes": [{"id": "data_umbrella_corp_policies_umbrella_corp", "label": "Umbrella Corporation", "file_type": "concept", "source_file": "data/umbrella_corp_policies.pdf", "source_location": "header", "source_url": null, "captured_at": null, "author": "Umbrella Corporation Human Resources Department", "contributor": null}, {"id": "data_umbrella_corp_policies_firststepai", "label": "FirstStepAI Onboarding System", "file_type": "concept", "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 1", "source_url": null, "captured_at": null, "author": "Umbrella Corporation Human Resources Department", "contributor": null, "rationale": "AI-driven onboarding platform that converts policy PDFs into 30-second intro videos and 10-question quizzes, eliminating the need for in-person trainers."}, {"id": "data_umbrella_corp_policies_assignment_rules", "label": "AI-Generated Assignment Rules (Annex K)", "file_type": "document", "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 4.7.1 Annex K", "source_url": null, "captured_at": null, "author": "Umbrella Corporation Human Resources Department", "contributor": null}, {"id": "data_umbrella_corp_policies_quiz_format", "label": "30-Second Intro Video + 10-Question Quiz", "file_type": "document", "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 1, section 4.7.1", "source_url": null, "captured_at": null, "author": "Umbrella Corporation Human Resources Department", "contributor": null, "rationale": "Designed to keep each policy chunk bite-sized (30s) so it is digestible, and quiz length (10 Q) balances assessment coverage against employee time."}, {"id": "data_umbrella_corp_policies_mixed_question_types", "label": "Mixed Multiple-Choice and Numerical Quiz", "file_type": "document", "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 4.7.1", "source_url": null, "captured_at": null, "author": "Umbrella Corporation Human Resources Department", "contributor": null}, {"id": "data_umbrella_corp_policies_llm_quiz_generation", "label": "LLM-Driven Quiz Generation", "file_type": "concept", "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 4.7.1", "source_url": null, "captured_at": null, "author": "Umbrella Corporation Human Resources Department", "contributor": null, "rationale": "Uses a large language model to author quiz items from the ingested policy text, avoiding hand-authored question banks."}, {"id": "data_umbrella_corp_policies_rag_chromadb", "label": "ChromaDB Vector Store + RAG Pipeline", "file_type": "concept", "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 4.7.1", "source_url": null, "captured_at": null, "author": "Umbrella Corporation Human Resources Department", "contributor": null, "rationale": "Policies are chunked and embedded into ChromaDB so the LLM only reasons over retrieved policy text, grounding generation in the source PDF."}, {"id": "data_umbrella_corp_policies_langchain_agents", "label": "LangChain Agent Orchestration", "file_type": "concept", "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 4.7.1", "source_url": null, "captured_at": null, "author": "Umbrella Corporation Human Resources Department", "contributor": null}, {"id": "data_umbrella_corp_policies_web_search_tools", "label": "Web Search Tools (DuckDuckGo, Arxiv, Wikipedia)", "file_type": "concept", "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 4.7.1", "source_url": null, "captured_at": null, "author": "Umbrella Corporation Human Resources Department", "contributor": null, "rationale": "Optional tools the agent can invoke when the local policy corpus lacks an answer; allow expansion beyond the static document."}, {"id": "data_umbrella_corp_policies_streamlit_frontend", "label": "Streamlit Frontend", "file_type": "concept", "source_file": "data/umbrella_corp_policies.pdf", "source_location": "section 4.7.1",